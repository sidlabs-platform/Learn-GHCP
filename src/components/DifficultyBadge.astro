---
interface Props {
  level: "beginner" | "intermediate" | "advanced";
}

const { level } = Astro.props;

const badgeConfig = {
  beginner: {
    emoji: "🟢",
    label: "Beginner",
    class: "badge-beginner",
  },
  intermediate: {
    emoji: "🟡",
    label: "Intermediate",
    class: "badge-intermediate",
  },
  advanced: {
    emoji: "🔴",
    label: "Advanced",
    class: "badge-advanced",
  },
};

const config = badgeConfig[level];
---

<span class={`difficulty-badge ${config.class}`}>
  {config.emoji}
  {config.label}
</span>

<style scoped>
  .difficulty-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.8rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .badge-beginner {
    background-color: #dcfce7;
    color: #166534;
    border: 1px solid #bbf7d0;
  }

  .badge-intermediate {
    background-color: #fef3c7;
    color: #92400e;
    border: 1px solid #fcd34d;
  }

  .badge-advanced {
    background-color: #fee2e2;
    color: #991b1b;
    border: 1px solid #fecaca;
  }
</style>
