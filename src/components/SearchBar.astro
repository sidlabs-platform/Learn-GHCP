---
// SearchBar component with placeholder for Pagefind integration
---

<div class="search-bar-container">
  <div class="search-bar">
    <span class="search-icon">🔍</span>
    <input
      type="text"
      class="search-input"
      placeholder="Search courses, features, tracks..."
      id="search-input"
    />
  </div>
</div>

<style scoped>
  .search-bar-container {
    width: 100%;
    margin-bottom: 2rem;
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0 1rem;
    background-color: #fff;
    border: 2px solid #e5e7eb;
    border-radius: 0.5rem;
    transition: border-color 0.3s;
  }

  .search-bar:focus-within {
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }

  .search-icon {
    font-size: 1.25rem;
    color: #9ca3af;
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    padding: 0.75rem 0;
    border: none;
    outline: none;
    font-size: 1rem;
    color: #111827;
  }

  .search-input::placeholder {
    color: #9ca3af;
  }
</style>

<script>
  // Placeholder for Pagefind integration
  // This script will be enhanced with actual search functionality
  const searchInput = document.getElementById("search-input");

  if (searchInput) {
    searchInput.addEventListener("input", (e) => {
      const query = (e.target as HTMLInputElement).value;
      // TODO: Integrate with Pagefind for actual search
      console.log("Search query:", query);
    });
  }
</script>
