---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';

export interface Props {
  title: string;
  description: string;
  track?: string;
  difficulty?: 'beginner' | 'intermediate' | 'advanced';
  estimatedMinutes?: number;
  prerequisites?: string[];
  personaTags?: string[];
  technologyTags?: string[];
  lastVerified?: string;
}

const { 
  title, 
  description, 
  track,
  difficulty = 'beginner',
  estimatedMinutes,
  prerequisites = [],
  personaTags = [],
  technologyTags = [],
  lastVerified,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Build a lookup map from prerequisite name → full course path
const allCourses = await getCollection('courses');
const prereqMap = new Map<string, string>();
for (const c of allCourses) {
  const courseId = c.id.replace(/\.mdx?$/, '');
  const fileName = courseId.split('/').pop()!;
  prereqMap.set(fileName, `${base}/courses/${courseId}/`);
}

// Map difficulty to display props
const difficultyConfig = {
  beginner: { icon: '🟢', label: 'Beginner', class: 'badge-beginner' },
  intermediate: { icon: '🟡', label: 'Intermediate', class: 'badge-intermediate' },
  advanced: { icon: '🔴', label: 'Advanced', class: 'badge-advanced' },
};

const diff = difficultyConfig[difficulty];

// Format last verified date
const formatDate = (dateString?: string) => {
  if (!dateString) return null;
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', { 
    year: 'numeric', 
    month: 'short', 
    day: 'numeric' 
  });
};

const formattedDate = formatDate(lastVerified);

// Generate GitHub issue URL for feedback
const generateIssueUrl = () => {
  const baseUrl = 'https://github.com/github/Learn-GHCP/issues/new';
  const params = new URLSearchParams({
    title: `Feedback: ${title}`,
    body: `Course: ${title}\n\nFeedback:\n\n(Please describe your feedback here)`,
    labels: 'feedback,course',
  });
  return `${baseUrl}?${params.toString()}`;
};

// Get the course slug from the URL or infer it
const currentUrl = Astro.url.pathname;
const courseSlug = currentUrl.split('/courses/')[1]?.split('/')[0] || '';
---

<BaseLayout title={title} description={description}>
  <article class="course-container">
    <!-- Course Header -->
    <header class="course-header">
      <div class="course-header-content">
        <h1 class="course-title">{title}</h1>
        <p class="course-description">{description}</p>
        
        <!-- Metadata Strip -->
        <div class="course-metadata-strip">
          <!-- Difficulty Badge -->
          <div class="metadata-item">
            <span class={`badge ${diff.class}`}>
              {diff.icon} {diff.label}
            </span>
          </div>

          <!-- Track -->
          {track && (
            <div class="metadata-item">
              <span class="metadata-label">Track:</span>
              <span class="metadata-value">{track}</span>
            </div>
          )}

          <!-- Estimated Time -->
          {estimatedMinutes && (
            <div class="metadata-item">
              <span class="metadata-label">Time:</span>
              <span class="metadata-value">{estimatedMinutes} min</span>
            </div>
          )}

          <!-- Last Verified -->
          {formattedDate && (
            <div class="metadata-item">
              <span class="metadata-label">Updated:</span>
              <span class="metadata-value">{formattedDate}</span>
            </div>
          )}
        </div>
      </div>
    </header>

    <!-- Course Content Grid -->
    <div class="course-content-wrapper">
      <!-- Main Content -->
      <main class="course-main">
        <slot />
      </main>

      <!-- Sidebar -->
      <aside class="course-sidebar">
        <!-- Prerequisites -->
        {prerequisites && prerequisites.length > 0 && (
          <section class="sidebar-section">
            <h2 class="sidebar-title">Prerequisites</h2>
            <ul class="prerequisites-list">
              {prerequisites.map((prereq) => (
                <li>
                  <a href={prereqMap.get(prereq) || `${base}/courses/${prereq}/`} class="prerequisite-link">
                    {prereq}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}

        <!-- Persona Tags -->
        {personaTags && personaTags.length > 0 && (
          <section class="sidebar-section">
            <h2 class="sidebar-title">For You</h2>
            <div class="tags-grid">
              {personaTags.map((tag) => (
                <span class="tag tag-persona">{tag}</span>
              ))}
            </div>
          </section>
        )}

        <!-- Technology Tags -->
        {technologyTags && technologyTags.length > 0 && (
          <section class="sidebar-section">
            <h2 class="sidebar-title">Technologies</h2>
            <div class="tags-grid">
              {technologyTags.map((tag) => (
                <span class="tag tag-technology">{tag}</span>
              ))}
            </div>
          </section>
        )}
      </aside>
    </div>

    <!-- Next Steps Section -->
    <section class="course-next-steps">
      <h2 class="next-steps-title">What's Next?</h2>
      <p class="next-steps-placeholder">
        <em>Additional course recommendations and next learning paths will appear here.</em>
      </p>
    </section>

    <!-- Feedback Section -->
    <section class="course-feedback">
      <div class="feedback-content">
        <h2 class="feedback-title">Was this helpful?</h2>
        <p class="feedback-description">
          We'd love to hear your feedback about this course. 
          <a href={generateIssueUrl()} target="_blank" rel="noopener noreferrer">
            Share your thoughts on GitHub
          </a>
        </p>
      </div>
    </section>
  </article>

  <style define:vars={{}}>
    /* Course Container */
    .course-container {
      max-width: 1280px;
      margin: 0 auto;
      padding: var(--space-lg);
    }

    /* Course Header */
    .course-header {
      margin-bottom: var(--space-3xl);
      padding-bottom: var(--space-2xl);
      border-bottom: 1px solid var(--color-border);
    }

    .course-header-content {
      max-width: 800px;
    }

    .course-title {
      font-size: var(--font-size-3xl);
      margin-bottom: var(--space-md);
      line-height: var(--line-height-tight);
    }

    .course-description {
      font-size: var(--font-size-lg);
      color: var(--color-muted);
      margin-bottom: var(--space-lg);
      line-height: var(--line-height-relaxed);
    }

    /* Metadata Strip */
    .course-metadata-strip {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-md);
      align-items: center;
    }

    .metadata-item {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
    }

    .metadata-label {
      color: var(--color-muted);
      font-size: var(--font-size-sm);
      font-weight: 500;
    }

    .metadata-value {
      color: var(--color-fg);
      font-size: var(--font-size-sm);
    }

    /* Course Content Layout */
    .course-content-wrapper {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: var(--space-2xl);
      margin-bottom: var(--space-3xl);
    }

    @media (max-width: var(--bp-lg)) {
      .course-content-wrapper {
        grid-template-columns: 1fr;
        gap: var(--space-2xl);
      }
    }

    .course-main {
      min-width: 0; /* Prevent overflow */
    }

    /* Main content typography */
    .course-main :global(h2) {
      font-size: var(--font-size-2xl);
      margin-top: var(--space-2xl);
      margin-bottom: var(--space-md);
    }

    .course-main :global(h3) {
      font-size: var(--font-size-xl);
      margin-top: var(--space-xl);
      margin-bottom: var(--space-md);
    }

    .course-main :global(p) {
      line-height: var(--line-height-relaxed);
      margin-bottom: var(--space-md);
    }

    .course-main :global(pre) {
      border: 1px solid var(--color-border);
    }

    /* Sidebar */
    .course-sidebar {
      display: flex;
      flex-direction: column;
      gap: var(--space-2xl);
    }

    @media (max-width: var(--bp-lg)) {
      .course-sidebar {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: var(--space-lg);
      }
    }

    .sidebar-section {
      background-color: var(--color-muted-bg);
      padding: var(--space-lg);
      border-radius: var(--radius-lg);
      border: 1px solid var(--color-border);
    }

    .sidebar-title {
      font-size: var(--font-size-md);
      font-weight: 600;
      margin-bottom: var(--space-md);
      color: var(--color-fg);
    }

    /* Prerequisites List */
    .prerequisites-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }

    .prerequisite-link {
      color: var(--color-accent);
      text-decoration: none;
      font-size: var(--font-size-sm);
      padding: var(--space-xs) var(--space-sm);
      border-radius: var(--radius-sm);
      transition: background-color var(--transition-fast);
    }

    .prerequisite-link:hover {
      background-color: var(--color-accent);
      color: white;
    }

    .prerequisite-link:focus-visible {
      outline: 2px solid var(--color-accent);
      outline-offset: 2px;
    }

    /* Tags Grid */
    .tags-grid {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-sm);
    }

    .tag {
      display: inline-block;
      padding: var(--space-xs) var(--space-md);
      border-radius: var(--radius-md);
      font-size: var(--font-size-xs);
      font-weight: 500;
      background-color: var(--color-bg);
      color: var(--color-fg);
      border: 1px solid var(--color-border);
      white-space: nowrap;
    }

    .tag-persona {
      background-color: rgba(9, 105, 218, 0.1);
      color: var(--color-accent);
      border-color: var(--color-accent);
    }

    .tag-technology {
      background-color: rgba(9, 105, 218, 0.08);
      color: var(--color-accent);
      border-color: var(--color-accent);
    }

    /* Next Steps Section */
    .course-next-steps {
      background-color: var(--color-muted-bg);
      padding: var(--space-2xl);
      border-radius: var(--radius-lg);
      border: 1px solid var(--color-border);
      margin-bottom: var(--space-2xl);
    }

    .next-steps-title {
      font-size: var(--font-size-xl);
      margin-bottom: var(--space-md);
    }

    .next-steps-placeholder {
      color: var(--color-muted);
      margin: 0;
    }

    /* Feedback Section */
    .course-feedback {
      background-color: var(--color-accent);
      color: white;
      padding: var(--space-2xl);
      border-radius: var(--radius-lg);
      text-align: center;
    }

    .feedback-title {
      font-size: var(--font-size-xl);
      margin-bottom: var(--space-md);
    }

    .feedback-description {
      margin: 0;
      opacity: 0.95;
    }

    .feedback-description a {
      color: white;
      text-decoration: underline;
      font-weight: 500;
    }

    .feedback-description a:hover {
      opacity: 0.8;
    }

    /* Responsive adjustments */
    @media (max-width: var(--bp-md)) {
      .course-container {
        padding: var(--space-md);
      }

      .course-title {
        font-size: var(--font-size-2xl);
      }

      .course-description {
        font-size: var(--font-size-md);
      }

      .course-metadata-strip {
        gap: var(--space-sm);
      }

      .course-feedback {
        padding: var(--space-lg);
      }
    }

    /* Print styles */
    @media print {
      .course-feedback,
      .course-next-steps,
      .course-sidebar {
        display: none;
      }
    }
  </style>
</BaseLayout>
