---
import { getCollection, render } from 'astro:content';
import CourseLayout from '../../layouts/CourseLayout.astro';

export async function getStaticPaths() {
  const courses = await getCollection('courses', ({ data }) => data.published);
  return courses.map((course) => ({
    params: { slug: course.id.replace(/\.mdx?$/, '') },
    props: { course },
  }));
}

const { course } = Astro.props;
const { Content } = await render(course);
const { data } = course;
---

<CourseLayout
  title={data.title}
  description={data.description}
  track={data.track}
  difficulty={data.difficulty}
  estimatedMinutes={data.estimatedMinutes}
  prerequisites={data.prerequisites}
  personaTags={data.personaTags}
  technologyTags={data.technologyTags}
  lastVerified={data.lastVerified?.toISOString()}
>
  <Content />
</CourseLayout>
