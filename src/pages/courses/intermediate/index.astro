---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CourseCard from '../../../components/CourseCard.astro';
import { getCollection } from 'astro:content';

const courses = await getCollection('courses', ({ data }) =>
  data.published && data.difficulty === 'intermediate'
);
---

<BaseLayout title="Intermediate Courses" description="Level up your Copilot skills with guided, real-world projects.">
  <div class="listing-container">
    <header class="listing-header">
      <h1>🟡 Intermediate Courses</h1>
      <p>Guided labs with real-world scenarios. Build working features with Copilot.</p>
    </header>

    {courses.length > 0 ? (
      <div class="courses-grid">
        {courses.map((course) => (
          <CourseCard
            title={course.data.title}
            description={course.data.description}
            difficulty={course.data.difficulty}
            track={course.data.track}
            estimatedMinutes={course.data.estimatedMinutes}
            slug={course.id.replace(/\.mdx?$/, '')}
          />
        ))}
      </div>
    ) : (
      <p class="no-courses">Intermediate courses are being generated. Check back soon!</p>
    )}
  </div>

  <style>
    .listing-container { max-width: 1100px; margin: 0 auto; padding: var(--space-xl); }
    .listing-header { margin-bottom: var(--space-2xl); }
    .listing-header h1 { font-size: var(--font-size-3xl); margin-bottom: var(--space-sm); }
    .listing-header p { color: var(--color-muted); font-size: var(--font-size-lg); }
    .courses-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: var(--space-lg); }
    .no-courses { color: var(--color-muted); font-style: italic; }
  </style>
</BaseLayout>
