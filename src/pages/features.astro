---
import BaseLayout from "../layouts/BaseLayout.astro";
import { readFileSync } from "fs";
import yaml from "js-yaml";
import { resolve } from "path";

// Read features data at build time
const featuresPath = resolve("data/features.yaml");
let features: any[] = [];

try {
  const fileContent = readFileSync(featuresPath, "utf-8");
  const data = yaml.load(fileContent) as any;
  features = data.features || [];
} catch (error) {
  console.error("Error reading features.yaml:", error);
  features = [];
}

// Group features by category
const categoriesMap = new Map<string, any[]>();
features.forEach((feature) => {
  const category = feature.category || "other";
  if (!categoriesMap.has(category)) {
    categoriesMap.set(category, []);
  }
  categoriesMap.get(category)!.push(feature);
});

const categoryLabels: Record<string, string> = {
  core: "Core Features",
  cli: "CLI Features",
  agents: "Agents & Agentic",
  extensibility: "Extensibility",
  github: "GitHub Integration",
  other: "Other",
};

const categoryEmojis: Record<string, string> = {
  core: "⭐",
  cli: "⌨️",
  agents: "🤖",
  extensibility: "🔌",
  github: "🐙",
  other: "📦",
};
---

<BaseLayout title="Feature Explorer">
  <main class="features-page">
    <section class="features-header">
      <h1>Feature Explorer</h1>
      <p>Discover all GitHub Copilot features across different categories</p>
      <div class="search-container">
        <input
          type="text"
          id="feature-search"
          class="feature-search"
          placeholder="Search features..."
        />
      </div>
    </section>

    <section class="features-stats">
      <div class="stat-card">
        <span class="stat-number">{features.length}</span>
        <span class="stat-label">Total Features</span>
      </div>
      <div class="stat-card">
        <span class="stat-number"
          >{features.filter((f) => f.status === "active").length}</span
        >
        <span class="stat-label">Active Features</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">{categoriesMap.size}</span>
        <span class="stat-label">Categories</span>
      </div>
    </section>

    <div id="features-container" class="features-container">
      {
        Array.from(categoriesMap.entries()).map(([category, categoryFeatures]) => (
          <section class="category-section" data-category={category}>
            <h2 class="category-title">
              <span>{categoryEmojis[category] || "📦"}</span>
              {categoryLabels[category] || category}
            </h2>
            <div class="features-list">
              {categoryFeatures.map((feature) => (
                <div class="feature-card" data-feature-name={feature.name.toLowerCase()}>
                  <div class="feature-header">
                    <h3 class="feature-name">{feature.name}</h3>
                    <span class={`status-badge status-${feature.status}`}>
                      {feature.status}
                    </span>
                  </div>
                  <p class="feature-description">{feature.description}</p>
                  {feature.relatedFeatures && feature.relatedFeatures.length > 0 && (
                    <div class="feature-related">
                      <strong>Related:</strong>
                      <span>{feature.relatedFeatures.join(", ")}</span>
                    </div>
                  )}
                  {feature.discoveredAt && (
                    <div class="feature-meta">
                      <span class="meta-item">
                        📅 {new Date(feature.discoveredAt).toLocaleDateString()}
                      </span>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </section>
        ))
      }
    </div>

    {features.length === 0 && (
      <section class="empty-state">
        <p>No features found. The features.yaml file may be empty or unavailable.</p>
      </section>
    )}
  </main>
</BaseLayout>

<script>
  // Client-side search functionality
  const searchInput = document.getElementById("feature-search") as HTMLInputElement;
  const featuresContainer = document.getElementById("features-container");
  const featureCards = document.querySelectorAll(".feature-card");
  const categorySection = document.querySelectorAll(".category-section");

  if (searchInput) {
    searchInput.addEventListener("input", (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase();

      featureCards.forEach((card) => {
        const featureName = card.getAttribute("data-feature-name") || "";
        const description = card.textContent?.toLowerCase() || "";

        if (
          featureName.includes(query) ||
          description.includes(query) ||
          query === ""
        ) {
          (card as HTMLElement).style.display = "block";
        } else {
          (card as HTMLElement).style.display = "none";
        }
      });

      // Hide empty category sections
      categorySection.forEach((section) => {
        const visibleCards = section.querySelectorAll(
          ".feature-card[style='display: block'], .feature-card:not([style])"
        ).length;
        const hiddenCards = section.querySelectorAll(
          ".feature-card[style*='display: none']"
        ).length;

        if (visibleCards === 0) {
          (section as HTMLElement).style.display = "none";
        } else {
          (section as HTMLElement).style.display = "block";
        }
      });
    });
  }
</script>

<style scoped>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .features-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .features-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    color: #111827;
  }

  .features-header p {
    font-size: 1rem;
    color: #6b7280;
    margin: 0 0 1.5rem 0;
  }

  .search-container {
    max-width: 500px;
    margin: 0 auto;
  }

  .feature-search {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    border: 2px solid #e5e7eb;
    border-radius: 0.5rem;
    transition: border-color 0.3s;
  }

  .feature-search:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }

  .features-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.5rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 0.5rem;
    color: white;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.875rem;
    opacity: 0.9;
  }

  .features-container {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .category-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .category-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    color: #111827;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .category-title span {
    font-size: 1.75rem;
  }

  .features-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 1.5rem;
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    border-color: #3b82f6;
    box-shadow: 0 10px 25px rgba(59, 130, 246, 0.1);
  }

  .feature-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .feature-name {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 700;
    color: #111827;
  }

  .status-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .status-active {
    background-color: #dcfce7;
    color: #166534;
  }

  .status-inactive {
    background-color: #f3f4f6;
    color: #4b5563;
  }

  .status-deprecated {
    background-color: #fee2e2;
    color: #991b1b;
  }

  .feature-description {
    margin: 0;
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.5;
  }

  .feature-related {
    margin-top: 0.5rem;
    padding: 0.75rem;
    background-color: #f9fafb;
    border-radius: 0.375rem;
    font-size: 0.8rem;
    color: #6b7280;
  }

  .feature-related strong {
    color: #111827;
  }

  .feature-related span {
    display: block;
    margin-top: 0.25rem;
    color: #3b82f6;
    word-break: break-word;
  }

  .feature-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
    color: #9ca3af;
    margin-top: 0.5rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .empty-state {
    text-align: center;
    padding: 2rem;
    color: #6b7280;
  }

  /* Responsive */
  @media (max-width: 768px) {
    main {
      padding: 1rem;
    }

    .features-header h1 {
      font-size: 1.875rem;
    }

    .features-list {
      grid-template-columns: 1fr;
    }

    .feature-header {
      flex-direction: column;
    }

    .status-badge {
      align-self: flex-start;
    }
  }
</style>
